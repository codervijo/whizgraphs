---
// src/pages/index.astro — WhizGraphs home. Standalone document (inlines the
// SEO baseline tags so the technical-SEO regression test passes) reusing the
// same chrome + global styles as Layout.astro.
import "../styles/global.css";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.tsx";
import Home from "../components/pages/Home.tsx";

const site = "https://whizgraphs.com";
const title = "WhizGraphs — Turn SEO data into shareable infographics";
const description =
  "WhizGraphs converts Search Console data into clean visual SEO reports for founders, consultants, and agencies.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={site} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="WhizGraphs — SEO infographics from your GSC data" />
    <meta property="og:description" content="Generate polished SEO infographics in seconds from Google Search Console-style data." />
    <meta property="og:url" content={site} />
    <meta property="og:site_name" content="WhizGraphs" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Prevent theme flash: apply persisted/system theme before paint -->
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem("whizgraphs-theme") || "system";
          var resolved =
            theme === "system"
              ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
              : theme;
          if (resolved === "dark") document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>

    <!-- JSON-LD structured data: Organization + WebSite -->
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://whizgraphs.com/#organization",
      "name": "WhizGraphs",
      "url": "https://whizgraphs.com"
    },
    {
      "@type": "WebSite",
      "@id": "https://whizgraphs.com/#website",
      "url": "https://whizgraphs.com",
      "name": "WhizGraphs",
      "publisher": { "@id": "https://whizgraphs.com/#organization" }
    }
  ]
}
    </script>
  </head>
  <body>
    <div class="flex min-h-screen flex-col bg-background">
      <Header client:load />
      <main class="flex-1">
        <Home />
      </main>
      <Footer />
    </div>
  </body>
</html>
